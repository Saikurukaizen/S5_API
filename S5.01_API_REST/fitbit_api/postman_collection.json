{
  "info": {
    "name": "Kaizen Fitbit API Tests",
    "description": "Colección de pruebas básicas para la API Kaizen Fitbit.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Registro de usuario",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/register", "host": ["{{base_url}}"], "path": ["api", "v1", "register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Juan\",\n  \"lastname\": \"Pérez\",\n  \"date_of_birth\": \"1990-01-01\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123!\",\n  \"password_confirmation\": \"Password123!\",\n  \"bank_acc\": \"ES1234567890\",\n  \"discipline_id\": 1\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/login", "host": ["{{base_url}}"], "path": ["api", "v1", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Obtener perfil propio",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/me", "host": ["{{base_url}}"], "path": ["api", "v1", "me"] }
      }
    },
    {
      "name": "Crear usuario (admin/moderador)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/users", "host": ["{{base_url}}"], "path": ["api", "v1", "users"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ana\",\n  \"lastname\": \"García\",\n  \"date_of_birth\": \"1992-05-10\",\n  \"email\": \"ana@example.com\",\n  \"password\": \"Password456!\",\n  \"password_confirmation\": \"Password456!\",\n  \"bank_acc\": \"ES0987654321\",\n  \"discipline_id\": 2\n}"
        }
      }
    },
    {
      "name": "Listar usuarios",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/users", "host": ["{{base_url}}"], "path": ["api", "v1", "users"] }
      }
    },
    {
      "name": "Crear comunidad (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/communities", "host": ["{{base_url}}"], "path": ["api", "v1", "communities"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Comunidad Boxeo\",\n  \"description\": \"Grupo para amantes del boxeo\",\n  \"discipline_id\": 1\n}"
        }
      }
    },
    {
      "name": "Añadir usuario a comunidad",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/communities/1/users/2", "host": ["{{base_url}}"], "path": ["api", "v1", "communities", "1", "users", "2"] }
      }
    },
    {
      "name": "Eliminar usuario de comunidad",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/communities/1/users/2", "host": ["{{base_url}}"], "path": ["api", "v1", "communities", "1", "users", "2"] }
      }
    },
    {
      "name": "Crear disciplina (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/disciplines", "host": ["{{base_url}}"], "path": ["api", "v1", "disciplines"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Karate\",\n  \"description\": \"Arte marcial japonés\"\n}"
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/logout", "host": ["{{base_url}}"], "path": ["api", "v1", "logout"] }
      }
    }
  ]
}
